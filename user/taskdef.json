{
  "family": "${CLUSTER}-user",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "${EXEC_ROLE_ARN}",
  "taskRoleArn": "${TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "user",
      "image": "bsathi2020/user:v1",
      "essential": true,
      "portMappings": [
        {"containerPort": 8080, "protocol": "tcp"}
      ],
      "environment": [
        {"name": "MONGO",     "value": "true"},
        {"name": "REDIS_URL", "value": "redis://redis.roboshop.local:6379"},
        {"name": "MONGO_URL", "value": "mongodb://mongodb.roboshop.local:27017/users"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/${CLUSTER}/user",
          "awslogs-region": "${REGION}",
          "awslogs-stream-prefix": "user"
        }
      }
    }
  ]
}
