{
  "family": "${CLUSTER}-mysql",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "${EXEC_ROLE_ARN}",
  "taskRoleArn": "${TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "mysql",
      "image": "bsathi2020/mysql:v1",
      "essential": true,
      "portMappings": [
        {"containerPort": 3306, "protocol": "tcp"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/${CLUSTER}/mysql",
          "awslogs-region": "${REGION}",
          "awslogs-stream-prefix": "mysql"
        }
      }
    }
  ]
}
